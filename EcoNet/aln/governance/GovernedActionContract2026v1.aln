!-- filename GovernedActionContract2026v1.aln --
!-- destination EcoNet/aln/governance/GovernedActionContract2026v1.aln --
!-- repo-target github.com/mk-bluebird/EcoNet --

aln
aln-spec v1.0
GovernedActionContract2026v1

description
Schema for governed action requests and effective contracts used by
Virta-Sys to mediate all superintelligent planning actions through
ALN request/response, never direct actuator access.
end-description

version 2026.06.24
owner-aln-id bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

type GovernedActionRequest2026v1
  field requestid
    type string
    required true
    pattern gar-2026-[A-Za-z0-9]{16}
  endfield

  field identityid
    type string
    required true
    comment
    Foreign key into BrainIdentityBindingShard2026v1.bindingid.
    end-comment
  endfield

  field soicref
    type string
    required true
    comment
    Sovereign Offshore Identity Credential identifier.
    end-comment
  endfield

  field agentorigin
    type string
    required true
    comment
    AI-chat, agent, or platform identifier issuing the request.
    end-comment
  endfield

  field actionkind
    type string
    required true
    enum IMAGE_RENDER, CODEGEN, SCHEDULE_RUN, DATA_EXPORT, OTHER
  endfield

  field payloadschemaid
    type string
    required true
    comment
    Reference into DefinitionRegistry for the payload schema that
    governs how Virta-Sys will complete this contract.
    end-comment
  endfield

  field payloadpartial
    type json
    required true
    comment
    Sparse fields provided by the user or agent (prompt, options,
    high-level spec). No raw neuromedical data.
    end-comment
  endfield

  field payloadpartialhash
    type string
    required true
    pattern 0x[0-9a-f]{64}
    comment
    HEXCOMMIT256 over canonical JSON encoding of payloadpartial.
    end-comment
  endfield

  field schemahash
    type string
    required true
    pattern 0x[0-9a-f]{64}
    comment
    HEXCOMMIT256 over canonical ALN/JSON form of the payload schema
    referenced by payloadschemaid.
    end-comment
  endfield

  field consentflags
    type json
    required true
    comment
    Explicit consent flags (e.g. allow_render_once, no_training,
    hashonly_evidence_only).
    end-comment
  endfield

  field neurorightsref
    type string
    required true
    comment
    Reference to neurorights policy shard (e.g. NeuroHashOnlyPolicy2026v1).
    end-comment
  endfield

  field blacklistref
    type string
    required true
    comment
    Reference to BlacklistAndHiddenControlAvoidance2026v1 or equivalent.
    end-comment
  endfield

  field laneintent
    type string
    required true
    enum RESEARCH, EXPPROD, PROD
  endfield

  field evidencehex
    type string
    required true
    pattern 0x[0-9A-Fa-f]{64}
    comment
    HEXCOMMIT256 over evidence bundle tying this request to identity,
    SOIC, agentorigin, and prompt shards.
    end-comment
  endfield

  field signinghex
    type string
    required true
    pattern 0x[0-9A-Fa-f]{128}
    comment
    Hex-encoded signature over the canonical request envelope.
    end-comment
  endfield

  field createdutc
    type string
    required true
    pattern 2026-[0-1][0-9]-[0-3][0-9]T[0-2][0-9]:[0-5][0-9]:[0-5][0-9]Z
  endfield
endtype

type EffectiveActionContract2026v1
  field contractid
    type string
    required true
    pattern eac-2026-[A-Za-z0-9]{16}
  endfield

  field requestid
    type string
    required true
    comment
    Back-reference to GovernedActionRequest2026v1.requestid.
    end-comment
  endfield

  field identityid
    type string
    required true
  endfield

  field actionkind
    type string
    required true
    enum IMAGE_RENDER, CODEGEN, SCHEDULE_RUN, DATA_EXPORT, OTHER
  endfield

  field lane
    type string
    required true
    enum RESEARCH, EXPPROD, PROD
  endfield

  field kerband
    type string
    required true
    enum SAFE, GUARDED, BLOCKED
  endfield

  field rohrisk
    type float
    required true
    min 0.0
    max 1.0
  endfield

  field ecoimpactclass
    type string
    required true
    enum NEUTRAL, RESTORATIVE, NEGATIVE
  endfield

  field payloadcomplete
    type json
    required true
    comment
    Fully completed payload (all required fields populated) used
    for actuation or downstream routing.
    end-comment
  endfield

  field contenthashhex
    type string
    required true
    pattern 0x[0-9a-f]{64}
    comment
    HEXCOMMIT256 over canonical encoding of this contract object.
    end-comment
  endfield

  field rohanchorhex
    type string
    required true
    pattern 0x[0-9a-f]{64}
    comment
    HEXCOMMIT256 over RoH policy context for this contract.
    end-comment
  endfield

  field vtresidual
    type float
    required true
    min 0.0
    max 1.0
  endfield

  field topologyrisk
    type float
    required true
    min 0.0
    max 1.0
  endfield

  field decisionverdict
    type string
    required true
    enum APPROVED, REJECTED_LANE, REJECTED_KER, REJECTED_NEURORIGHTS,
         REJECTED_BLACKLIST, REJECTED_ECO, REJECTED_TOPOLOGY
  endfield

  field decisionexplanation
    type string
    required true
  endfield

  field issuedby
    type string
    required true
    comment
    Must be Virta-Sys identity for production contracts.
    end-comment
  endfield

  field issuedutc
    type string
    required true
    pattern 2026-[0-1][0-9]-[0-3][0-9]T[0-2][0-9]:[0-5][0-9]:[0-5][0-9]Z
  endfield
endtype

section invariants
  invariant RequestHashOnlyNeuro
    description
    Governed action requests must not carry raw neuromedical fields; only
    hash commitments and HASHONLY policy references are allowed.
    end-description
    condition
      forall r in GovernedActionRequest2026v1 .
        r.neurorightsref != ""
    end-condition
  endinvariant
endsection

end-aln
